10 REM PETSCII BLOCK GRAPHICS TEST
20 REM CHR$(96-127): HLINE VLINE CROSS CORNERS TEES
30 REM DIAGONALS CHECKER HALVES QUADRANTS SPECIAL
40 PRINT
50 PRINT "PETSCII BLOCK GRAPHICS TEST"
60 PRINT
70 REM -- ALL 32 GLYPHS IN ONE ROW
80 PRINT "ALL GLYPHS CHR$(96-127):"
90 FOR A=96 TO 127
100   PRINT CHR$(A);
110 NEXT A
120 PRINT
130 PRINT
140 REM -- CODE/GLYPH TABLE, 4 PER LINE
150 PRINT "CODE TABLE:"
160 FOR B=96 TO 124 STEP 4
170   FOR C=0 TO 3
180     PRINT B+C;":";CHR$(B+C);" ";
190   NEXT C
200   PRINT
210 NEXT B
220 PRINT
230 REM -- BOX DRAWING DEMO
240 PRINT "BOX DEMO:"
250 W=30
260 PRINT CHR$(99);
270 FOR D=1 TO W-2
280   PRINT CHR$(96);
290 NEXT D
300 PRINT CHR$(100)
310 FOR E=1 TO 2
320   PRINT CHR$(97);
330   FOR F=1 TO W-2
340     PRINT " ";
350   NEXT F
360   PRINT CHR$(97)
370 NEXT E
380 PRINT CHR$(101);
390 FOR G=1 TO W-2
400   PRINT CHR$(96);
410 NEXT G
420 PRINT CHR$(102)
430 PRINT
440 REM -- FILL PATTERNS
450 PRINT "FILL PATTERNS:"
460 FOR H=109 TO 115
470   FOR K=1 TO 5
480     PRINT CHR$(H);
490   NEXT K
500   PRINT " ";
510 NEXT H
520 PRINT
530 PRINT "SPECIAL:"
540 PRINT CHR$(121);" DIAMOND  ";CHR$(122);" BALL  ";CHR$(127);" BLOCK"
550 END
