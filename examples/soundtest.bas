5 REM *** FPGA SOUND CHIP TEST ***
10 REM CHANNEL 0 AT $8830-$8839
15 REM FL=FREQ_LO FH=FREQ_HI VO=VOLUME CO=CONTROL
20 FL=34864:FH=34865:VO=34868:CO=34869
25 SQ=17:NO=65:OF=0
30 REM SQ=$11 SQUARE+GATE  NO=$41 NOISE+GATE  OF=GATE OFF
35 POKE VO,200
40 PRINT "FPGA SOUND CHIP TEST"
50 PRINT
60 PRINT "1 = SCALE (SQUARE)"
70 PRINT "2 = SIREN"
80 PRINT "3 = NOISE BURST"
90 PRINT "4 = LITTLE MELODY"
100 PRINT "Q = QUIT"
110 PRINT
120 GET K$:IF K$="" THEN 120
130 IF K$="1" THEN GOSUB 1000
140 IF K$="2" THEN GOSUB 2000
150 IF K$="3" THEN GOSUB 3000
160 IF K$="4" THEN GOSUB 4000
170 IF K$="Q" THEN END
180 GOTO 40
200 REM === PLAY F=FREQ FOR D LOOPS ===
210 POKE FL,F AND 255
220 POKE FH,INT(F/256)
230 POKE CO,SQ
240 FOR T=1 TO D:NEXT
250 POKE CO,OF
260 RETURN
1000 REM === C MAJOR SCALE ===
1010 FOR I=0 TO 7
1020 READ F:D=300:GOSUB 210
1030 NEXT
1040 RESTORE
1050 RETURN
2000 REM === SIREN SWEEP ===
2010 POKE CO,SQ
2020 FOR F=300 TO 900 STEP 20
2030 POKE FL,F AND 255:POKE FH,INT(F/256)
2040 FOR T=1 TO 30:NEXT
2050 NEXT
2060 FOR F=900 TO 300 STEP -20
2070 POKE FL,F AND 255:POKE FH,INT(F/256)
2080 FOR T=1 TO 30:NEXT
2090 NEXT
2100 POKE CO,OF
2110 RETURN
3000 REM === NOISE BURST ===
3010 POKE FL,200:POKE FH,0
3020 POKE CO,NO
3030 FOR T=1 TO 800:NEXT
3040 POKE CO,OF
3050 RETURN
4000 REM === SHORT MELODY ===
4005 RESTORE:FOR I=0 TO 7:READ X:NEXT
4010 FOR I=0 TO 6
4020 READ F,D:GOSUB 210
4030 NEXT
4040 RESTORE
4050 RETURN
5000 REM === C-MAJOR SCALE DATA (USED BY 1000) ===
5010 DATA 262,294,330,349,392,440,494,523
6000 REM === MELODY DATA (FREQ,DURATION) USED BY 4000 ===
6010 DATA 392,200,392,200,440,400,392,400
6020 DATA 523,400,494,600,0,150
