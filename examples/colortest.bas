5 REM *** FPGA VIC COLOR TEST ***
10 V=32768:K=33792:B$=CHR$(160)
20 POKE 36867,1:POKE 36868,0
30 GOSUB 9000
100 REM === TITLE BAR (WHITE ON BLUE) ===
110 POKE 36867,1:POKE 36868,6
120 PRINT "    FPGA VIC COLOR TEST V1.0            ";
130 POKE 36867,15:POKE 36868,0:PRINT
200 REM === 16-COLOR PALETTE ===
210 PRINT " PALETTE:"
220 FOR C=0 TO 7:POKE 36867,C:POKE 36868,11
230 PRINT B$;B$;B$;B$;B$;:NEXT
240 POKE 36867,12:POKE 36868,0
250 PRINT "  0    1    2    3    4    5    6    7"
260 FOR C=8 TO 15:POKE 36867,C:POKE 36868,11
270 PRINT B$;B$;B$;B$;B$;:NEXT
280 POKE 36867,12:POKE 36868,0
290 PRINT "  8    9   10   11   12   13   14   15"
295 PRINT
300 REM === TEXT COLOR DEMO ===
310 POKE 36867,2:PRINT " RED ";
320 POKE 36867,5:PRINT "GREEN ";
330 POKE 36867,6:PRINT "BLUE ";
340 POKE 36867,7:PRINT "YELLOW ";
350 POKE 36867,3:PRINT "CYAN ";
360 POKE 36867,4:PRINT "PURPLE"
370 PRINT
400 REM === BACKGROUND COLOR DEMO ===
410 POKE 36867,1
420 POKE 36868,2:PRINT " RED ";
430 POKE 36868,6:PRINT " BLU ";
440 POKE 36868,5:PRINT " GRN ";
450 POKE 36868,7:PRINT " YEL ";
460 POKE 36867,0
470 POKE 36868,3:PRINT " CYN ";
480 POKE 36867,1:POKE 36868,4:PRINT " PUR ";
490 POKE 36868,8:PRINT " ONG ";
500 POKE 36868,9:PRINT " BRN ";
510 POKE 36867,1:POKE 36868,0:PRINT
600 REM === PETSCII ART (RAINBOW FRAME) ===
610 R=PEEK(237):IF R>18 THEN R=18
620 O=R*40
630 REM -- TOP BORDER (CYAN) --
640 POKE V+O,99:POKE V+O+39,100
650 FOR I=1 TO 38:POKE V+O+I,96:NEXT
660 FOR I=0 TO 39:POKE K+O+I,3:NEXT
670 REM -- FILL BODY WITH RAINBOW MOSAIC --
680 FOR Y=1 TO 5:O1=(R+Y)*40
690 POKE V+O1,97:POKE K+O1,3
700 POKE V+O1+39,97:POKE K+O1+39,3
710 FOR X=1 TO 38
720 C=X-1+Y*3:C=C-INT(C/14)*14+1
730 POKE K+O1+X,C
740 CH=127:IF (X+Y) AND 1 THEN CH=123
750 POKE V+O1+X,CH:NEXT:NEXT
760 REM -- BOTTOM BORDER --
770 O2=(R+6)*40
780 POKE V+O2,101:POKE V+O2+39,102
790 FOR I=1 TO 38:POKE V+O2+I,96:NEXT
800 FOR I=0 TO 39:POKE K+O2+I,3:NEXT
810 REM -- CURSOR BELOW FRAME --
820 POKE 237,R+7:POKE 36866,R+7
830 POKE 236,0:POKE 36865,0
840 POKE 36867,15:POKE 36868,0
850 PRINT " POKE 36867,FG : POKE 36868,BG"
860 POKE 36867,1:POKE 36868,0
870 END
9000 REM === CLEAR SCREEN ===
9010 FOR I=0 TO 999
9020 POKE V+I,32:POKE K+I,1
9030 NEXT
9040 POKE 236,0:POKE 237,0
9050 POKE 36865,0:POKE 36866,0
9060 RETURN
