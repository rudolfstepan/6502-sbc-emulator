1 REM *** CRYPT OF THE 6502 ***
2 REM *** A TEXT ADVENTURE FOR THE SBC6502 ***
3 REM *** BY RUDOLF STEPAN / CLAUDE ***
10 GOSUB 5000
20 GOSUB 1000
30 PRINT
40 PRINT "CMD> ";
50 INPUT C$
60 IF C$="N" THEN GOSUB 2100:GOTO 20
70 IF C$="S" THEN GOSUB 2200:GOTO 20
80 IF C$="E" THEN GOSUB 2300:GOTO 20
90 IF C$="W" THEN GOSUB 2400:GOTO 20
100 IF C$="TAKE" THEN GOSUB 6000:GOTO 20
110 IF C$="DROP" THEN GOSUB 6100:GOTO 20
120 IF C$="INV" THEN GOSUB 3000:GOTO 20
130 IF C$="LOOK" THEN GOSUB 1000:GOTO 20
140 IF C$="FIGHT" THEN GOSUB 7000:GOTO 20
150 IF C$="HELP" THEN GOSUB 4000:GOTO 20
160 IF C$="QUIT" THEN PRINT "FAREWELL!":END
170 PRINT "UNKNOWN CMD. TRY HELP."
180 GOTO 30

1000 REM *** DESCRIBE CURRENT ROOM ***
1010 PRINT
1020 PRINT "=== ";RN$(R);" ==="
1030 PRINT RD$(R)
1040 IF R=6 AND MD=0 THEN PRINT "A GIANT GUARD STANDS HERE!"
1050 IF R=6 AND MD=1 THEN PRINT "THE GUARD LIES DEFEATED."
1060 IF (RI(R) AND 1)=1 THEN PRINT "YOU SEE: BOOK"
1070 IF (RI(R) AND 2)=2 THEN PRINT "YOU SEE: KEY"
1080 IF (RI(R) AND 4)=4 THEN PRINT "YOU SEE: SWORD"
1090 IF (RI(R) AND 8)=8 THEN PRINT "YOU SEE: CHIP"
1100 PRINT "EXITS:";
1110 IF EX(R,1)>0 THEN PRINT " N";
1120 IF EX(R,2)>0 THEN PRINT " S";
1130 IF EX(R,3)>0 THEN PRINT " E";
1140 IF EX(R,4)>0 THEN PRINT " W";
1150 PRINT
1160 RETURN

2100 REM *** GO NORTH ***
2110 IF EX(R,1)=0 THEN PRINT "NO EXIT NORTH.":RETURN
2120 R=EX(R,1):GOSUB 1000:RETURN

2200 REM *** GO SOUTH ***
2210 IF EX(R,2)=0 THEN PRINT "NO EXIT SOUTH.":RETURN
2220 R=EX(R,2):GOSUB 1000:RETURN

2300 REM *** GO EAST ***
2310 NR=EX(R,3)
2320 IF NR=0 THEN PRINT "NO EXIT EAST.":RETURN
2330 IF R=6 AND MD=0 THEN PRINT "THE GUARD BLOCKS YOUR WAY!":RETURN
2340 IF R=6 AND NR=7 THEN GOSUB 2500
2350 IF NR=0 THEN RETURN
2360 R=NR
2370 IF R=8 THEN GOSUB 9900:RETURN
2380 GOSUB 1000:RETURN

2400 REM *** GO WEST ***
2410 IF EX(R,4)=0 THEN PRINT "NO EXIT WEST.":RETURN
2420 R=EX(R,4):GOSUB 1000:RETURN

2500 REM *** TRY VAULT DOOR ***
2510 IF (IN AND 2)=0 THEN PRINT "THE VAULT IS LOCKED!":NR=0:RETURN
2520 PRINT "YOU USE THE KEY - DOOR OPENS!"
2530 IN=IN-2
2540 RETURN

3000 REM *** INVENTORY ***
3010 PRINT "CARRYING:";
3020 IF IN=0 THEN PRINT " NOTHING":RETURN
3030 IF (IN AND 1)=1 THEN PRINT " BOOK";
3040 IF (IN AND 2)=2 THEN PRINT " KEY";
3050 IF (IN AND 4)=4 THEN PRINT " SWORD";
3060 IF (IN AND 8)=8 THEN PRINT " CHIP";
3070 PRINT:RETURN

4000 REM *** HELP ***
4010 PRINT "COMMANDS:"
4020 PRINT " N S E W    - MOVE"
4030 PRINT " TAKE DROP  - ITEMS"
4040 PRINT " INV LOOK   - STATUS"
4050 PRINT " FIGHT      - ATTACK"
4060 PRINT " HELP QUIT"
4070 RETURN

5000 REM *** INITIALISE GAME ***
5010 DIM RN$(8),RD$(8),RI(8),EX(8,4)
5020 R=1:MD=0:IN=0:NR=0
5030 REM ROOM NAMES
5040 RN$(1)="CELL"
5050 RN$(2)="CORRIDOR"
5060 RN$(3)="LIBRARY"
5070 RN$(4)="LAB"
5080 RN$(5)="ARMORY"
5090 RN$(6)="GUARD ROOM"
5100 RN$(7)="VAULT"
5110 RN$(8)="EXIT"
5120 REM ROOM DESCRIPTIONS
5130 RD$(1)="YOU AWAKE IN A DARK STONE CELL."
5140 RD$(2)="A LONG TORCHLIT CORRIDOR."
5150 RD$(3)="DUSTY SHELVES OF ANCIENT BOOKS."
5160 RD$(4)="STRANGE EQUIPMENT. A DEAD END."
5170 RD$(5)="OLD WEAPONS LINE THE WALLS."
5180 RD$(6)="A CHAMBER BEFORE THE VAULT."
5190 RD$(7)="A GOLDEN CHAMBER. VERY OLD."
5200 RD$(8)="YOU SEE DAYLIGHT AHEAD!"
5210 REM EXITS N,S,E,W (0=NONE)
5220 EX(1,1)=0:EX(1,2)=0:EX(1,3)=2:EX(1,4)=0
5230 EX(2,1)=3:EX(2,2)=5:EX(2,3)=6:EX(2,4)=1
5240 EX(3,1)=0:EX(3,2)=2:EX(3,3)=0:EX(3,4)=0
5250 EX(4,1)=0:EX(4,2)=0:EX(4,3)=0:EX(4,4)=5
5260 EX(5,1)=2:EX(5,2)=0:EX(5,3)=4:EX(5,4)=0
5270 EX(6,1)=5:EX(6,2)=0:EX(6,3)=7:EX(6,4)=2
5280 EX(7,1)=0:EX(7,2)=6:EX(7,3)=8:EX(7,4)=0
5290 EX(8,1)=0:EX(8,2)=7:EX(8,3)=0:EX(8,4)=0
5300 REM ROOM ITEMS: 1=BOOK 2=KEY 4=SWORD 8=CHIP
5310 RI(1)=0:RI(2)=0:RI(3)=3:RI(4)=0:RI(5)=4:RI(6)=0:RI(7)=8:RI(8)=0
5320 PRINT CHR$(12)
5330 PRINT "*** CRYPT OF THE 6502 ***"
5340 PRINT
5350 PRINT "YOU MUST FIND THE GOLDEN 6502 CHIP"
5360 PRINT "AND ESCAPE THE ANCIENT CRYPT."
5370 PRINT
5380 PRINT "MAP HINT:"
5390 PRINT " [LIBRARY]"
5400 PRINT "    |N-S"
5410 PRINT " [CELL]-E-[CORRIDOR]-E-[GUARD ROOM]"
5420 PRINT "              |S      -E-[VAULT]-E-[EXIT]"
5430 PRINT "           [ARMORY]-E-[LAB]"
5440 PRINT
5450 PRINT "PRESS RETURN TO BEGIN..."
5460 INPUT A$
5470 PRINT CHR$(12)
5480 RETURN

6000 REM *** TAKE ITEM ***
6010 PRINT "TAKE WHAT? ";
6020 INPUT IT$
6030 IF IT$="BOOK" AND (RI(R) AND 1)=1 THEN RI(R)=RI(R)-1:IN=IN+1:PRINT "BOOK TAKEN.":RETURN
6040 IF IT$="KEY" AND (RI(R) AND 2)=2 THEN RI(R)=RI(R)-2:IN=IN+2:PRINT "KEY TAKEN.":RETURN
6050 IF IT$="SWORD" AND (RI(R) AND 4)=4 THEN RI(R)=RI(R)-4:IN=IN+4:PRINT "SWORD TAKEN.":RETURN
6060 IF IT$="CHIP" AND (RI(R) AND 8)=8 THEN RI(R)=RI(R)-8:IN=IN+8:PRINT "CHIP TAKEN.":RETURN
6070 PRINT "NOT HERE.":RETURN

6100 REM *** DROP ITEM ***
6110 PRINT "DROP WHAT? ";
6120 INPUT IT$
6130 IF IT$="BOOK" AND (IN AND 1)=1 THEN IN=IN-1:RI(R)=RI(R)+1:PRINT "DROPPED.":RETURN
6140 IF IT$="KEY" AND (IN AND 2)=2 THEN IN=IN-2:RI(R)=RI(R)+2:PRINT "DROPPED.":RETURN
6150 IF IT$="SWORD" AND (IN AND 4)=4 THEN IN=IN-4:RI(R)=RI(R)+4:PRINT "DROPPED.":RETURN
6160 IF IT$="CHIP" AND (IN AND 8)=8 THEN IN=IN-8:RI(R)=RI(R)+8:PRINT "DROPPED.":RETURN
6170 PRINT "YOU DON'T HAVE THAT.":RETURN

7000 REM *** FIGHT ***
7010 IF R<>6 THEN PRINT "NO ENEMY HERE.":RETURN
7020 IF MD=1 THEN PRINT "ALREADY DEFEATED.":RETURN
7030 IF (IN AND 4)=0 THEN PRINT "YOU NEED A SWORD!":RETURN
7040 MD=1
7050 PRINT "YOU SLASH WITH YOUR SWORD!"
7060 PRINT "THE GUARD FALLS! PATH CLEAR."
7070 RETURN

9900 REM *** WIN SEQUENCE ***
9910 IF (IN AND 8)=0 THEN PRINT "NO CHIP! GO BACK FOR IT!":R=7:GOSUB 1000:RETURN
9920 PRINT CHR$(12)
9930 PRINT "*** YOU WIN! ***"
9940 PRINT
9950 PRINT "YOU ESCAPE WITH THE GOLDEN 6502 CHIP!"
9960 PRINT
9970 PRINT "CONGRATULATIONS!"
9980 PRINT
9990 PRINT "THE 6502 POWERS ON..."
9995 END
