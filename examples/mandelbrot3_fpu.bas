5 REM *** MANDELBROT SET - BITMAP MODE FAST BASIC ***
6 REM 320X200 PIXEL, 16 C64 COLORS
7 REM BYTE PACKED VERSION: 8 PIXELS PER POKE
10 DIM M(7),CL(16)
15 M(0)=128:M(1)=64:M(2)=32:M(3)=16
20 M(4)=8:M(5)=4:M(6)=2:M(7)=1
25 CL(1)=6:CL(2)=14:CL(3)=3:CL(4)=13
26 CL(5)=5:CL(6)=7:CL(7)=10:CL(8)=2
27 CL(9)=8:CL(10)=9:CL(11)=4:CL(12)=12
28 CL(13)=15:CL(14)=1:CL(15)=11:CL(16)=11
30 BM=36880:CM=33792:MI=16
35 SX=3.0/320:SY=2.4/200
40 POKE 36864,1
50 FOR I=0 TO 7999:POKE BM+I,0:NEXT
55 FOR I=0 TO 999:POKE CM+I,0:NEXT
60 CI=-1.2:RO=0:CY=0:YC=0
65 FOR Y=0 TO 199
70 CR=-2.1
75 FOR XB=0 TO 39
80 B=0:CC=0
85 FOR XP=0 TO 7
90 ZR=0:ZI=0
95 FOR N=1 TO MI
100 TR=ZR*ZR:TI=ZI*ZI
105 IF TR+TI>4 THEN 130
110 ZI=2*ZR*ZI+CI:ZR=TR-TI+CR
115 NEXT N
120 GOTO 140
130 B=B OR M(XP):CC=N
140 CR=CR+SX
145 NEXT XP
150 IF B<>0 THEN POKE BM+RO+XB,B
155 IF CC<>0 THEN POKE CM+CY+XB,CL(CC)
160 NEXT XB
165 CI=CI+SY:RO=RO+40:YC=YC+1
170 IF YC=8 THEN YC=0:CY=CY+40
175 NEXT Y
180 GET K$:IF K$="" THEN 180
185 POKE 36864,0