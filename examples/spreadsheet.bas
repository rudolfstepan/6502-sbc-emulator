1 REM *** SHEET64 - SMALL SPREADSHEET FOR SBC6502 MS BASIC ***
2 REM *** LOAD "SPREADSHEET.PRG" THEN RUN ***
10 NR=10:NC=4:CW=8:DIM V(40),K(40),T$(40)
20 GOSUB 8000
30 GOSUB 1000
40 PRINT "CELL OR ? ";:INPUT C$
50 IF C$="Q" THEN END
60 IF C$="?" THEN GOSUB 7000:GOTO 30
70 IF C$="R" THEN GOSUB 3000:GOTO 30
80 IF C$="C" THEN GOSUB 6000:GOTO 30
90 GOSUB 2000
100 IF I=0 THEN PRINT "BAD CELL":GOSUB 9000:GOTO 30
110 PRINT C$;" = ";:INPUT X$
120 T$(I)=X$:K(I)=1
130 IF X$="" THEN K(I)=0:V(I)=0
140 IF LEFT$(X$,1)="'" THEN K(I)=2
150 GOSUB 3000
160 GOTO 30
1000 REM *** DRAW SHEET ***
1010 GOSUB 8000
1020 PRINT "SHEET64  A1-D10  ? HELP  Q QUIT"
1030 PRINT "     A       B       C       D"
1040 FOR R=1 TO NR
1050 PRINT RIGHT$("  "+STR$(R),3);" ";
1060 FOR C=1 TO NC
1070 I=(R-1)*NC+C:GOSUB 4000:GOSUB 5000
1080 NEXT C
1090 PRINT
1100 NEXT R
1110 PRINT
1120 PRINT "EDIT: A1 THEN 12 OR =A1+B1"
1130 RETURN
2000 REM *** PARSE CELL C$ -> I ***
2010 I=0:IF C$="" THEN RETURN
2020 C=ASC(LEFT$(C$,1))-64:R=VAL(MID$(C$,2))
2030 IF C<1 OR C>NC OR R<1 OR R>NR THEN RETURN
2040 I=(R-1)*NC+C:RETURN
3000 REM *** RECALCULATE NUMERIC CELLS ***
3010 FOR J=1 TO 3
3020 FOR I=1 TO NR*NC
3030 IF K(I)<>1 THEN 3090
3040 X$=T$(I)
3050 IF X$="" THEN V(I)=0:GOTO 3090
3060 IF LEFT$(X$,1)="=" THEN F$=MID$(X$,2):GOSUB 3200:V(I)=OV:GOTO 3090
3070 V(I)=VAL(X$)
3090 NEXT I
3100 NEXT J
3110 RETURN
3200 REM *** EVALUATE FORMULA F$ -> OV ***
3210 P=0:OP$=""
3220 FOR L=1 TO LEN(F$)
3230 A$=MID$(F$,L,1)
3240 IF A$="+" OR A$="-" OR A$="*" OR A$="/" THEN P=L:OP$=A$:L=LEN(F$)
3250 NEXT L
3260 IF P=0 THEN O$=F$:GOSUB 3300:RETURN
3270 O$=LEFT$(F$,P-1):GOSUB 3300:A=OV
3280 O$=MID$(F$,P+1):GOSUB 3300:B=OV
3290 OV=A
3291 IF OP$="+" THEN OV=A+B:RETURN
3292 IF OP$="-" THEN OV=A-B:RETURN
3293 IF OP$="*" THEN OV=A*B:RETURN
3294 IF OP$="/" AND B<>0 THEN OV=A/B:RETURN
3295 IF OP$="/" THEN OV=0:RETURN
3299 RETURN
3300 REM *** EVALUATE OPERAND O$ -> OV ***
3310 OV=0:IF O$="" THEN RETURN
3320 A$=LEFT$(O$,1):C=ASC(A$)-64:R=VAL(MID$(O$,2))
3330 IF C>=1 AND C<=NC AND R>=1 AND R<=NR THEN OV=V((R-1)*NC+C):RETURN
3340 OV=VAL(O$):RETURN
4000 REM *** CELL DISPLAY STRING D$ ***
4010 D$=""
4020 IF K(I)=0 THEN RETURN
4030 IF K(I)=2 THEN D$=MID$(T$(I),2):GOTO 4060
4040 D$=STR$(V(I))
4060 IF LEN(D$)>CW THEN D$=LEFT$(D$,CW)
4070 RETURN
5000 REM *** PRINT D$ PADDED TO CW ***
5010 IF LEN(D$)>CW THEN D$=LEFT$(D$,CW)
5020 PRINT D$;
5030 IF LEN(D$)<CW THEN PRINT SPC(CW-LEN(D$));
5040 RETURN
6000 REM *** CLEAR ALL CELLS ***
6010 FOR I=1 TO NR*NC:V(I)=0:K(I)=0:T$(I)="":NEXT I
6020 RETURN
7000 REM *** HELP ***
7010 GOSUB 8000
7020 PRINT "SHEET64 COMMANDS"
7030 PRINT
7040 PRINT "A1-D10  EDIT CELL"
7050 PRINT "R       RECALC"
7060 PRINT "C       CLEAR SHEET"
7070 PRINT "Q       QUIT"
7080 PRINT
7090 PRINT "CELL CONTENT:"
7100 PRINT "12          NUMBER"
7110 PRINT "'PARTS      LABEL"
7120 PRINT "=A1+B1      FORMULA"
7130 PRINT "=A1-B1 =A1*B1 =A1/B1"
7140 PRINT
7150 PRINT "NO SPACES INSIDE FORMULAS."
7160 GOSUB 9000
7170 RETURN
8000 REM *** CLEAR TEXT SCREEN ***
8010 FOR I=0 TO 999
8020 POKE 32768+I,32:POKE 33792+I,1
8030 NEXT I
8040 POKE 236,0:POKE 237,0
8050 POKE 36865,0:POKE 36866,0
8060 RETURN
9000 REM *** WAIT FOR RETURN ***
9010 PRINT "PRESS RETURN ";:INPUT A$
9020 RETURN
