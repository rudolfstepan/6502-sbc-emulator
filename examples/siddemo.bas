1 REM ====================================
2 REM  SID-STYLE ADSR DEMO - FPGA 4-VOICE
3 REM  SOUND CHIP ($8830 / $8890 / $889A)
4 REM ====================================
5 REM THE FPGA CHIP HAS NO NOTE QUEUE: EACH
6 REM POKE OF CONTROL+1 RETRIGGERS THE VOICE
7 REM IMMEDIATELY, SO NOTES MUST BE PLAYED
8 REM ONE AT A TIME WITH A DELAY BETWEEN.
9 REM DURATION (DUR_LO/HI IN MS) AUTO-STOPS
10 REM A NOTE; THE ADSR REGISTERS SHAPE IT.
11 REM ------------------------------------
12 REM REGISTER OFFSETS PER VOICE:
13 REM +0/+1 FREQ LO/HI   +2/+3 DUR LO/HI
14 REM +4 VOL  +5 CTRL  +6 ATK  +7 DEC
15 REM +8 SUS  +9 REL    CTRL=1 => SINE+GATE
16 REM ------------------------------------
17 REM TM = FOR-LOOP COUNTS PER MS OF NOTE.
18 REM GP = GAP BETWEEN NOTES IN MS.
19 TM=15
20 GP=140
30 POKE 34868,220:POKE 34964,200:POKE 34974,200
40 PRINT "===================================="
50 PRINT " SID ADSR DEMO - FPGA 4-VOICE CHIP"
60 PRINT "===================================="
70 PRINT
80 PRINT "PRESS A KEY TO START"
90 GOSUB 950
100 PRINT
110 PRINT "1) FLAT    (A=0 D=0 S=255 R=0)"
120 POKE 34870,0:POKE 34871,0:POKE 34872,255:POKE 34873,0
130 GOSUB 800
140 PRINT "   PRESS A KEY..."
150 GOSUB 950
160 PRINT
170 PRINT "2) PIANO   (A=8 D=6 S=160 R=15)"
180 POKE 34870,8:POKE 34871,6:POKE 34872,160:POKE 34873,15
190 GOSUB 800
200 PRINT "   PRESS A KEY..."
210 GOSUB 950
220 PRINT
230 PRINT "3) STRINGS (A=30 D=15 S=200 R=40)"
240 POKE 34870,30:POKE 34871,15:POKE 34872,200:POKE 34873,40
250 GOSUB 800
260 PRINT "   PRESS A KEY..."
270 GOSUB 950
280 PRINT
290 PRINT "4) ORGAN   (A=0 D=0 S=220 R=20)"
300 POKE 34870,0:POKE 34871,0:POKE 34872,220:POKE 34873,20
310 GOSUB 800
320 PRINT "   PRESS A KEY..."
330 GOSUB 950
340 PRINT
350 PRINT "--- 3-VOICE CHORD (C-E-G) ---"
355 REM VOICE 0 PIANO, VOICES 1+2 STRINGS
360 POKE 34870,8:POKE 34871,6:POKE 34872,160:POKE 34873,15
370 POKE 34966,30:POKE 34967,15:POKE 34968,200:POKE 34969,40
380 POKE 34976,30:POKE 34977,15:POKE 34978,200:POKE 34979,40
390 DM=1500
400 POKE 34866,DM AND 255:POKE 34867,INT(DM/256)
405 POKE 34962,DM AND 255:POKE 34963,INT(DM/256)
410 POKE 34972,DM AND 255:POKE 34973,INT(DM/256)
420 POKE 34864,523 AND 255:POKE 34865,INT(523/256)
430 POKE 34960,659 AND 255:POKE 34961,INT(659/256)
440 POKE 34970,784 AND 255:POKE 34971,INT(784/256)
450 POKE 34869,1:POKE 34965,1:POKE 34975,1
460 FOR T=1 TO DM*TM:NEXT
470 PRINT "   PRESS A KEY..."
480 GOSUB 950
490 PRINT
500 PRINT "===================================="
510 PRINT " TETRIS THEME (KOROBEINIKI) - PIANO"
520 PRINT "===================================="
530 PRINT
540 POKE 34870,4:POKE 34871,4:POKE 34872,140:POKE 34873,8
550 RESTORE
560 READ F:IF F<0 THEN 600
570 READ DM
580 GOSUB 900
590 GOTO 560
600 PRINT "DEMO COMPLETE. THANK YOU!"
610 END
799 REM === PLAY C-E-G-C ARPEGGIO ON VOICE 0 ===
800 F=523:DM=600:GOSUB 900
810 F=659:DM=600:GOSUB 900
820 F=784:DM=600:GOSUB 900
830 F=1047:DM=900:GOSUB 900
840 RETURN
899 REM === PLAY ONE NOTE ON VOICE 0 (F=HZ,DM=STEP MS) ===
900 ND=DM-GP
905 IF ND<60 THEN ND=60
910 POKE 34866,ND AND 255:POKE 34867,INT(ND/256)
920 POKE 34864,F AND 255:POKE 34865,INT(F/256)
930 POKE 34869,1
940 FOR T=1 TO DM*TM:NEXT
945 RETURN
949 REM === WAIT FOR A KEYPRESS ===
950 GET K$:IF K$="" THEN 950
960 RETURN
1000 REM === TETRIS MELODY: FREQ,DURATION(MS) ===
1010 DATA 659,500,494,250,523,250,587,500,523,250,494,250
1020 DATA 440,500,440,250,523,250,659,500,587,250,523,250
1030 DATA 494,750,523,250,587,500,659,500,523,500,440,500
1040 DATA 440,1000,587,750,698,250,880,500,784,250,698,250
1050 DATA 659,750,523,250,659,500,587,250,523,250,494,500
1060 DATA 494,250,523,250,587,500,659,500,523,500,440,500
1070 DATA 440,1000
1080 DATA -1,0