5 REM *** MANDELBROT SET - BITMAP MODE ***
6 REM 320X200 PIXEL, 16 C64 COLORS
7 REM APPROX 20 MIN ON 1 MHZ 6502
10 DIM M(7),CL(15)
15 M(0)=128:M(1)=64:M(2)=32:M(3)=16
20 M(4)=8:M(5)=4:M(6)=2:M(7)=1
25 CL(1)=6:CL(2)=14:CL(3)=3:CL(4)=13
26 CL(5)=5:CL(6)=7:CL(7)=10:CL(8)=2
27 CL(9)=8:CL(10)=9:CL(11)=4:CL(12)=12
28 CL(13)=15:CL(14)=1:CL(15)=11
30 BM=36880:CM=33792:MI=16
40 POKE 36864,1
50 FOR I=0 TO 7999:POKE BM+I,0:NEXT
55 FOR I=0 TO 999:POKE CM+I,0:NEXT
60 SX=3.0/320:SY=2.4/200
65 FOR Y=0 TO 199
66 RO=Y*40:CY=INT(Y/8)*40
70 CI=-1.2+Y*SY
75 FOR X=0 TO 319
76 BX=INT(X/8):BT=M(X AND 7)
80 CR=-2.1+X*SX
85 ZR=0:ZI=0
90 FOR N=1 TO MI
95 TR=ZR*ZR:TI=ZI*ZI
100 IF TR+TI>4 THEN 130
105 ZI=2*ZR*ZI+CI:ZR=TR-TI+CR
110 NEXT N
115 GOTO 150
130 POKE BM+RO+BX,PEEK(BM+RO+BX) OR BT
140 C=N:IF C>15 THEN C=15
145 POKE CM+CY+BX,CL(C)
150 NEXT X
155 NEXT Y
160 GET K$:IF K$="" THEN 160
165 POKE 36864,0
