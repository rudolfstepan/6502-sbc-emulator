10 W=64:H=32:I=20
20 FOR Y=0 TO H-1
30 CY=-1.2+Y*2.4/H
40 FOR X=0 TO W-1
50 CX=-2+X*3/W
60 ZX=0:ZY=0:N=0
70 XX=ZX*ZX:YY=ZY*ZY
80 IF XX+YY>4 THEN 140
90 IF N>=I THEN 140
100 ZY=2*ZX*ZY+CY
110 ZX=XX-YY+CX
120 N=N+1
130 GOTO 70
140 C=32
150 IF N>=3 THEN C=46
160 IF N>=6 THEN C=42
170 IF N>=10 THEN C=111
180 IF N>=15 THEN C=64
190 IF N>=I THEN C=35
200 PRINT CHR$(C);
210 NEXT X
220 PRINT
230 NEXT Y
240 END
